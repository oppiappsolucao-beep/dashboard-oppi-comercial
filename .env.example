# Variáveis de ambiente — Dashboard Oppi Comercial (Easypanel)

# Login do dashboard (obrigatório)
APP_USERNAME=oppitech
APP_PASSWORD=

# Sessão (opcional — usa APP_PASSWORD se vazio)
SESSION_SECRET=

# Google Sheets (obrigatório para dados)
GCP_SERVICE_ACCOUNT_B64=

# Porta (Easypanel geralmente define automaticamente)
PORT=8501

