# Variáveis de ambiente — Dashboard Oppi Comercial (Easypanel)

# Login do dashboard (obrigatório)
APP_USERNAME=oppitech
APP_PASSWORD=

# Sessão (opcional — usa APP_PASSWORD se vazio)
SESSION_SECRET=

# Google Sheets (obrigatório para dados)
GCP_SERVICE_ACCOUNT_B64=

# Planilha comercial (opcional — padrão: Planilha Oppi Comercial / Folha1)
GOOGLE_SHEET_ID=1GAbrca0NSiJfPXaSte1qGxXCsGkQPacoRsm0PVB51gE
GOOGLE_WORKSHEET_NAME=Folha1

# Modelo de proposta em Google Docs (opcional)
PROPOSAL_TEMPLATE_DOC_ID=1iTBG1ZUMCVB-aS7QoYiC4Sym6Dgn9Z7gMN-LGLgyprI
# Pasta do Drive/Shared Drive para cópias temporárias do PDF (opcional, evita erro de cota)
PROPOSAL_PDF_FOLDER_ID=

# WhatsApp de contato Oppi (opcional)
SUPPORT_WHATSAPP_NUMBER=5511920679171
SUPPORT_WHATSAPP_LABEL=+55 11 92067-9171

# Evolution API — Atendimentos WhatsApp
# EVOLUTION_API_URL=https://sua-evolution.exemplo.com
# EVOLUTION_API_KEY=
# EVOLUTION_INSTANCE=nome-da-instancia
# Token opcional para validar webhook (header X-Evolution-Token ou ?token=)
# EVOLUTION_WEBHOOK_TOKEN=
# Webhook público a configurar na Evolution:
# https://comercial.oppitech.com.br/webhooks/evolution

# IA de atendimento (estrutura; prompt depois)
# AI_ATTENDANCE_ENABLED=0
# AI_ATTENDANCE_PROMPT=

# Porta (Easypanel geralmente define automaticamente)
PORT=8501

# Pasta persistente para usuários, metas e configurações locais (recomendado no Easypanel)
APP_STORAGE_DIR=/app/storage

# --- CRM Streamlit (opcional, deploy separado) ---
# DATABASE_URL=
# APP_SECRET_KEY=
