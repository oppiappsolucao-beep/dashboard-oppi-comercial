# Oppi CRM Comercial - variáveis de ambiente (exemplo)
# Copie para .env e preencha os valores reais

APP_NAME=Oppi CRM Comercial
APP_SECRET_KEY=change-me-in-production
APP_TIMEZONE=America/Sao_Paulo
APP_CURRENCY=BRL
SESSION_TIMEOUT_MINUTES=480

# Produção: PostgreSQL
# DATABASE_URL=postgresql+psycopg2://usuario:senha@host:5432/oppi_crm

# Desenvolvimento: SQLite (padrão quando DATABASE_URL não estiver definida)
# DATABASE_URL=sqlite:///./oppi_crm.db

# Seed de demonstração (NÃO usar em produção)
RUN_SEED_ON_STARTUP=false

# IA
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# WhatsApp
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# n8n
N8N_WEBHOOK_URL=

# Asaas
ASAAS_API_KEY=
ASAAS_API_URL=https://api.asaas.com/v3

# ZapSign
ZAPSIGN_API_TOKEN=
ZAPSIGN_API_URL=https://api.zapsign.com.br/api/v1

# E-mail
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Google Sheets (opcional)
GCP_SERVICE_ACCOUNT_B64=
